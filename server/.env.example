PORT=3000
# Local dev
BASE_URL=http://localhost:3000 # Use your backend/server url here

# Hosted / HTTPS
# BASE_URL=https://my-url-shortener.com | Use your backend/server url here

# Required by sqlx at compile time
DATABASE_URL=sqlite:urls.db

# Rate limit variables for tower_governor
RATE_LIMIT_PER_SECOND=10 # client gets 10 tokens per second
RATE_LIMIT_BURST=30 # maximal 30 tokens per client

# Single allowed origin for CORS. Empty = CORS disabled.
CORS_ORIGIN=http://localhost:5173